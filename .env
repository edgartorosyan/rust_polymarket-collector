# Polymarket Collector Environment Variables

# Logging level (error, warn, info, debug, trace)
RUST_LOG=info

# Chainlink Data Streams credentials (requires paid subscription).
# Contact: https://chain.link/contact?ref_id=datastreams
# When set, prices come from Chainlink. When absent, Binance is used as fallback.
# CHAINLINK_API_KEY=
# CHAINLINK_API_SECRET=

# PostgreSQL connection string
DATABASE_URL=postgres://polymarket_collector:great_polymarket_collector@localhost:5432/polymarket_collector

# Optional: override default API base URLs
# CLOB_BASE_URL=https://clob.polymarket.com
# GAMMA_BASE_URL=https://gamma-api.polymarket.com

# Toggle full orderbook streaming + persistence (orderbook_snapshots table).
# Accepts: true / 1 / yes / on (case-insensitive). Defaults to false.
WITH_ORDERBOOK=false
